{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@lowcode/types": ["../../packages/types/src"],
      "@lowcode/schema": ["../../packages/schema/src"],
      "@lowcode/utils": ["../../packages/utils/src"],
      "@lowcode/components": ["../../packages/components/src"]
    }
  },
  "include": ["src", "../../packages/types/src", "../../packages/schema/src", "../../packages/utils/src", "../../packages/components/src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
